{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Story",
  "description": "LLM 输出的故事 JSON schema。generate_story.py 用 jsonschema 校验。",
  "type": "object",
  "required": ["title_en", "title_zh", "sentences"],
  "additionalProperties": false,
  "properties": {
    "title_en": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "title_zh": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "sentences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "en", "zh"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^s\\d{2,}$"
          },
          "en": {
            "type": "string",
            "minLength": 1
          },
          "zh": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
